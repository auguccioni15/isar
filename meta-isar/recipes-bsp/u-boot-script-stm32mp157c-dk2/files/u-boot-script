# Root filesystem partition (set by U-Boot distro_bootpart)
ROOT_PARTITION="${distro_bootpart}"

# Kernel command line arguments for STM32MP157C-DK2
# root=LABEL=rootfs: ext4 filesystem label set by WKS --label rootfs (not GPT PARTLABEL)
# earlycon: DT-based (stdout-path); the explicit stm32_serial form fails with OP-TEE dk2 DTS
KERNEL_ARGS="root=LABEL=rootfs rootwait rw console=ttySTM0,115200 earlycon clk_ignore_unused nomodeset panic=60 initcall_debug ignore_loglevel"

# No device tree overlays needed
OVERLAYS=""

# Include initrd if present
NO_INITRD=""

# No U-Boot commands to prepend
SCRIPT_PREPEND=""

# Use DTB from bootfs, not U-Boot built-in
BUILTIN_DT="no"
